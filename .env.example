# Copy to .env for local development (never commit .env).

# PostgreSQL connection string (local, Neon, Supabase, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Local Vite only: where /api is proxied during `pnpm run dev`
API_PROXY_TARGET=http://127.0.0.1:8080

# API server port (local or Render sets this automatically)
PORT=8080

# Gemini API (optional): used for AI resume match scoring
# Create a key in Google AI Studio and paste it here
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Optional: override model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# After deploying the API (e.g. Render), put the public URL here, then update vercel.json:
# PUBLIC_API_URL=https://your-service.onrender.com
