{
  "installCommand": "pnpm install --frozen-lockfile --filter @workspace/hr-system... --config.production=false",
  "buildCommand": "pnpm --config.production=false --filter @workspace/hr-system run build",
  "outputDirectory": "artifacts/hr-system/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://doctor-hospital-hub-api.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
