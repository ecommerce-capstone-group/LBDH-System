{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0 <25"
  },
  "scripts": {
    "preinstall": "node scripts/preinstall-enforce-pnpm.mjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:fix-applicants": "node lib/db/scripts/ensure-applicant-columns.mjs",
    "db:migrate-appraisals": "node lib/db/scripts/migrate-appraisals.mjs",
    "db:migrate-training-appraisals": "node lib/db/scripts/migrate-training-appraisals.mjs",
    "db:diagnose-appraisals": "node lib/db/scripts/diagnose-appraisals.mjs",
    "db:seed": "pnpm --filter @workspace/scripts run seed:hr"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
